<?xml version="1.0" encoding="utf-8"?>
<set xmlns:android="http://schemas.android.com/apk/res/android">

    <translate
        android:duration="70"
        android:fromXDelta="-10"
        android:toXDelta="10"
        android:repeatCount="5"
        android:repeatMode="reverse"/>

    <rotate
        android:duration="70"
        android:fromDegrees="-3"
        android:toDegrees="3"
        android:repeatCount="5"
        android:repeatMode="reverse"/>

</set>