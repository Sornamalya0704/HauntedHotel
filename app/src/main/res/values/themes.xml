<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.HauntedHotel" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/dark_bg</item>
        <item name="android:statusBarColor">@color/darker_bg</item>
        <item name="android:navigationBarColor">@color/darker_bg</item>
        <item name="android:textColor">@color/ghost_white</item>
        <item name="colorPrimary">@color/dark_red</item>
        <item name="colorPrimaryDark">@color/blood_red</item>
        <item name="colorAccent">@color/gold</item>
    </style>

    <style name="Theme.HauntedHotel.Transparent" parent="Theme.HauntedHotel">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:backgroundDimEnabled">true</item>
    </style>
</resources>