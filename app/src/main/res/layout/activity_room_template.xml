<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/dark_bg"
    android:padding="16dp">

    <!-- Top Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="20dp">

        <Button
            android:id="@+id/backButton"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="@string/back_button"
            android:backgroundTint="@color/wood"
            android:textColor="@color/gold"
            android:textSize="14sp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"/>

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1"/>

        <TextView
            android:id="@+id/roomNumber"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ROOM XXX"
            android:textColor="@color/dark_red"
            android:textSize="18sp"
            android:textStyle="bold"/>

    </LinearLayout>

    <!-- Room Title Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginBottom="24dp">

        <TextView
            android:id="@+id/roomTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🚪 ROOM XXX 🚪"
            android:textSize="28sp"
            android:textColor="@color/dark_red"
            android:textStyle="bold"
            android:letterSpacing="0.05"/>

        <TextView
            android:id="@+id/ghostName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ghost Name"
            android:textSize="20sp"
            android:textColor="@color/gold"
            android:textStyle="italic"
            android:layout_marginTop="8dp"/>

        <View
            android:layout_width="60dp"
            android:layout_height="2dp"
            android:background="@color/dark_red"
            android:layout_marginTop="16dp"/>

    </LinearLayout>

    <!-- Visual Elements Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="24dp">

        <!-- Door -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <View
                android:id="@+id/doorView"
                android:layout_width="100dp"
                android:layout_height="120dp"
                android:background="@drawable/door_background"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🚪 DOOR"
                android:textSize="10sp"
                android:textColor="@color/fog"
                android:layout_marginTop="8dp"/>

        </LinearLayout>

        <!-- Ghost -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

           <ImageView
                android:id="@+id/ghostImage"
                android:layout_width="90dp"
                android:layout_height="90dp"
                android:src="@drawable/ghost_phantom"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="👻 SPIRIT"
                android:textSize="10sp"
                android:textColor="@color/fog"
                android:layout_marginTop="8dp"/>

        </LinearLayout>

    </LinearLayout>

    <!-- Ghost Message Card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/card_bg"
        android:padding="20dp"
        android:layout_marginBottom="24dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/ghostMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="👻 'I can't leave until you know my secret...'"
            android:textSize="16sp"
            android:textColor="@color/gold"
            android:gravity="center"
            android:lineSpacingExtra="4dp"/>

    </LinearLayout>

    <!-- Flag Input Section -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/flag_hint"
        android:textSize="12sp"
        android:textColor="@color/gold"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <EditText
        android:id="@+id/flagInput"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:hint="CTF{...}"
        android:textColorHint="@color/fog"
        android:textColor="@color/ghost_white"
        android:background="@drawable/input_bg"
        android:padding="16dp"
        android:textSize="14sp"
        android:fontFamily="monospace"
        android:inputType="text"
        android:layout_marginBottom="20dp"/>

    <!-- Checkout Button -->
    <Button
        android:id="@+id/checkoutButton"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:text="@string/checkout_button"
        android:backgroundTint="@color/dark_red"
        android:textColor="@color/ghost_white"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"/>

    <!-- Hint Section -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="💡 HINT: The ghost whispers about reverse engineering..."
        android:textSize="11sp"
        android:textColor="#665555"
        android:gravity="center"
        android:padding="12dp"
        android:background="@color/card_bg"/>

    <!-- Progress Indicator -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="16dp">

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1"
            android:background="@color/fog"/>

        <TextView
            android:id="@+id/progressText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1/8 GUESTS"
            android:textSize="10sp"
            android:textColor="@color/fog"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"/>

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1"
            android:background="@color/fog"/>

    </LinearLayout>

</LinearLayout>