<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dark_bg"
    android:padding="12dp">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="20dp">

            <!-- Hotel Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/lobby_title"
                    android:textColor="@color/gold"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/splash_subtitle"
                    android:textColor="@color/dark_red"
                    android:textSize="12sp"
                    android:textStyle="italic"
                    android:layout_marginTop="5dp"/>

                <View
                    android:layout_width="80dp"
                    android:layout_height="2dp"
                    android:background="@color/dark_red"
                    android:layout_marginTop="12dp"/>

            </LinearLayout>

            <!-- Counter Box -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@color/card_bg"
                android:padding="16dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="24dp"
                android:gravity="center">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/counter_label"
                    android:textColor="@color/gold"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:gravity="center"/>

                <TextView
                    android:id="@+id/counterText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0/8"
                    android:textColor="@color/dark_red"
                    android:textSize="28sp"
                    android:textStyle="bold"/>

            </LinearLayout>

            <!-- Rooms Grid -->
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:rowCount="4"
                android:padding="8dp">

                <!-- Room 101 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@color/card_bg"
                    android:padding="16dp"
                    android:minHeight="140dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="101"
                        android:textColor="@color/gold"
                        android:textSize="24sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="The Phantom"
                        android:textColor="@color/fog"
                        android:textSize="12sp"
                        android:layout_marginTop="8dp"/>

                    <View
                        android:layout_width="40dp"
                        android:layout_height="1dp"
                        android:background="@color/dark_red"
                        android:layout_marginTop="12dp"/>

                    <Button
                        android:id="@+id/door101"
                        android:layout_width="match_parent"
                        android:layout_height="36dp"
                        android:layout_marginTop="12dp"
                        android:text="ENTER"
                        android:background="@drawable/room_button"
                        android:textColor="@color/gold"
                        android:textSize="12sp"/>

                </LinearLayout>

                <!-- Room 102 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@color/card_bg"
                    android:padding="16dp"
                    android:minHeight="140dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="102"
                        android:textColor="@color/gold"
                        android:textSize="24sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="The Whisperer"
                        android:textColor="@color/fog"
                        android:textSize="12sp"
                        android:layout_marginTop="8dp"/>

                    <View
                        android:layout_width="40dp"
                        android:layout_height="1dp"
                        android:background="@color/dark_red"
                        android:layout_marginTop="12dp"/>

                    <Button
                        android:id="@+id/door102"
                        android:layout_width="match_parent"
                        android:layout_height="36dp"
                        android:layout_marginTop="12dp"
                        android:text="ENTER"
                        android:background="@drawable/room_button"
                        android:textColor="@color/gold"
                        android:textSize="12sp"/>

                </LinearLayout>

                <!-- Room 103 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@color/card_bg"
                    android:padding="16dp"
                    android:minHeight="140dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="103"
                        android:textColor="@color/gold"
                        android:textSize="24sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="The Shadow"
                        android:textColor="@color/fog"
                        android:textSize="12sp"
                        android:layout_marginTop="8dp"/>

                    <View
                        android:layout_width="40dp"
                        android:layout_height="1dp"
                        android:background="@color/dark_red"
                        android:layout_marginTop="12dp"/>

                    <Button
                        android:id="@+id/door103"
                        android:layout_width="match_parent"
                        android:layout_height="36dp"
                        android:layout_marginTop="12dp"
                        android:text="ENTER"
                        android:background="@drawable/room_button"
                        android:textColor="@color/gold"
                        android:textSize="12sp"/>

                </LinearLayout>

                <!-- Room 104 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@color/card_bg"
                    android:padding="16dp"
                    android:minHeight="140dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="104"
                        android:textColor="@color/gold"
                        android:textSize="24sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="The Mirror"
                        android:textColor="@color/fog"
                        android:textSize="12sp"
                        android:layout_marginTop="8dp"/>

                    <View
                        android:layout_width="40dp"
                        android:layout_height="1dp"
                        android:background="@color/dark_red"
                        android:layout_marginTop="12dp"/>

                    <Button
                        android:id="@+id/door104"
                        android:layout_width="match_parent"
                        android:layout_height="36dp"
                        android:layout_marginTop="12dp"
                        android:text="ENTER"
                        android:background="@drawable/room_button"
                        android:textColor="@color/gold"
                        android:textSize="12sp"/>

                </LinearLayout>

                <!-- Room 105 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@color/card_bg"
                    android:padding="16dp"
                    android:minHeight="140dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="105"
                        android:textColor="@color/gold"
                        android:textSize="24sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="The Crying Lady"
                        android:textColor="@color/fog"
                        android:textSize="12sp"
                        android:layout_marginTop="8dp"/>

                    <View
                        android:layout_width="40dp"
                        android:layout_height="1dp"
                        android:background="@color/dark_red"
                        android:layout_marginTop="12dp"/>

                    <Button
                        android:id="@+id/door105"
                        android:layout_width="match_parent"
                        android:layout_height="36dp"
                        android:layout_marginTop="12dp"
                        android:text="ENTER"
                        android:background="@drawable/room_button"
                        android:textColor="@color/gold"
                        android:textSize="12sp"/>

                </LinearLayout>

                <!-- Room 106 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@color/card_bg"
                    android:padding="16dp"
                    android:minHeight="140dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="106"
                        android:textColor="@color/gold"
                        android:textSize="24sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="The Collector"
                        android:textColor="@color/fog"
                        android:textSize="12sp"
                        android:layout_marginTop="8dp"/>

                    <View
                        android:layout_width="40dp"
                        android:layout_height="1dp"
                        android:background="@color/dark_red"
                        android:layout_marginTop="12dp"/>

                    <Button
                        android:id="@+id/door106"
                        android:layout_width="match_parent"
                        android:layout_height="36dp"
                        android:layout_marginTop="12dp"
                        android:text="ENTER"
                        android:background="@drawable/room_button"
                        android:textColor="@color/gold"
                        android:textSize="12sp"/>

                </LinearLayout>

                <!-- Room 107 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@color/card_bg"
                    android:padding="16dp"
                    android:minHeight="140dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="107"
                        android:textColor="@color/gold"
                        android:textSize="24sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="The Apparition"
                        android:textColor="@color/fog"
                        android:textSize="12sp"
                        android:layout_marginTop="8dp"/>

                    <View
                        android:layout_width="40dp"
                        android:layout_height="1dp"
                        android:background="@color/dark_red"
                        android:layout_marginTop="12dp"/>

                    <Button
                        android:id="@+id/door107"
                        android:layout_width="match_parent"
                        android:layout_height="36dp"
                        android:layout_marginTop="12dp"
                        android:text="ENTER"
                        android:background="@drawable/room_button"
                        android:textColor="@color/gold"
                        android:textSize="12sp"/>

                </LinearLayout>

                <!-- Room 108 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@color/card_bg"
                    android:padding="16dp"
                    android:minHeight="140dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="108"
                        android:textColor="@color/gold"
                        android:textSize="24sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="The Final Truth"
                        android:textColor="@color/fog"
                        android:textSize="12sp"
                        android:layout_marginTop="8dp"/>

                    <View
                        android:layout_width="40dp"
                        android:layout_height="1dp"
                        android:background="@color/dark_red"
                        android:layout_marginTop="12dp"/>

                    <Button
                        android:id="@+id/door108"
                        android:layout_width="match_parent"
                        android:layout_height="36dp"
                        android:layout_marginTop="12dp"
                        android:text="ENTER"
                        android:background="@drawable/room_button"
                        android:textColor="@color/gold"
                        android:textSize="12sp"/>

                </LinearLayout>

            </GridLayout>

            <!-- Footer Message -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="@string/footer_hint"
                android:textColor="@color/fog"
                android:textSize="12sp"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="20dp"/>

        </LinearLayout>
    </ScrollView>

</RelativeLayout>